# The flagship: turn messy text on stdin into schema-validated NDJSON, one row per
# input line. Each row matches the schema (ai_json validates and retries once) or the
# run stops with the field that didn't validate. No SDK, no JSON glue, one binary.
#
#   cat tickets.txt | loqi examples/ai/extract.lq > tickets.ndjson
#
# Needs: curl on PATH and ANTHROPIC_API_KEY in the env.

let schema = {
  type: "object",
  required: ["id", "severity", "summary"],
  fields: {
    id:       { type: "int", min: 1 },
    severity: { type: "string", enum: ["low", "medium", "high", "critical"] },
    summary:  { type: "string", min_length: 3 },
  },
}

# temperature 0: same input -> same row, so the next pipe stage is reproducible.
let opts = { model: "claude-sonnet-4-6", temperature: 0 }

for line in lines(stdin()) {
  if trim(line) == "" { continue }
  let row = ai_json("Extract id, severity and summary from this support ticket:\n{line}", schema, opts)
  print(json.stringify(row))   # one NDJSON line, validated
}
