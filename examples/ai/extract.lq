# Structured extraction: ask for JSON and get back native Loqi data directly.
# `{ json: true }` steers the model, strips any ```fences```, and parses for you,
# no HTTP libraries, no JSON glue, no SDK.
#   ANTHROPIC_API_KEY=... loqi examples/ai/extract.lq

let text = "Ada Lovelace, born in 1815, is considered the first programmer."

let data = ai("Extract name, birth_year (int) and role from: {text}", { json: true })

print("Name: {data.name}")
print("Year: {data.birth_year}")
print("Role: {data.role}")
