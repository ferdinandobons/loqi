# Structured extraction: the AI produces JSON, `json.parse` turns it into native data.
# All built-in: no HTTP libraries, no JSON parser, no SDK.
#   ANTHROPIC_API_KEY=... loqi examples/ai/extract.lq

let text = "Ada Lovelace, born in 1815, is considered the first programmer."

let prompt = "Extract name, birth_year (int) and role from the text. " +
             "Respond ONLY with valid JSON, no other text.\n\n" + text

let json_str = ai(prompt)
let data = json.parse(json_str)

print("Name: {data.name}")
print("Year: {data.birth_year}")
print("Role: {data.role}")
