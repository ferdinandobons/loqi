# HTTP e JSON sono nel linguaggio: fetch + parse in due righe, zero dipendenze.
# (Richiede solo una connessione di rete.)
#   loqi examples/ai/web.lq

let repo = json.parse(http.get("https://api.github.com/repos/python/cpython"))
print("{repo.full_name}: {repo.stargazers_count} stelle ⭐")

