# L'AI è di prima classe in Loqi: `ai(...)` chiama un LLM, niente SDK da installare.
# Richiede la variabile d'ambiente ANTHROPIC_API_KEY.
#   ANTHROPIC_API_KEY=... loqi examples/ai/haiku.lq

let argomento = "il mare d'inverno"
let poesia = ai("Scrivi un haiku in italiano su {argomento}. Solo la poesia.")
print(poesia)
