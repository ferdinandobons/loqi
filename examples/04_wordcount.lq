# Word count: shows maps, lists, and higher-level functions.
let text = "loqi is simple loqi is fast loqi is ai first"

let counts = {}
for word in split(text, " ") {
  if has(counts, word) {
    counts[word] = counts[word] + 1
  } else {
    counts[word] = 1
  }
}

print("Unique words: {len(counts)}")
for word in counts {
  print("  {word}: {counts[word]}")
}
