# pad_start / pad_end
assert(pad_start("5", 3, "0") == "005", "pad_start with fill")
assert(pad_end("5", 3, "0") == "500", "pad_end with fill")
assert(pad_start("7", 4) == "   7", "pad_start default space")
assert(pad_end("hi", 5) == "hi   ", "pad_end default space")
assert(pad_start("hello", 3) == "hello", "no pad when already wide enough")
assert(pad_start("ab", 6, "xy") == "xyxyab", "cyclic fill")

# lines
assert(lines("a\nb\nc") == ["a", "b", "c"], "lines basic")
assert(lines("a\r\nb") == ["a", "b"], "lines strips CR (CRLF)")
assert(lines("a\nb\n") == ["a", "b"], "lines drops trailing-newline empty")
assert(lines("") == [], "lines of empty string is empty")
assert(lines("a\n\nb") == ["a", "", "b"], "lines keeps internal blank line")
assert(lines("solo") == ["solo"], "lines of one line")

# words
assert(words("  hello   world ") == ["hello", "world"], "words collapses whitespace")
assert(words("one\ttwo\nthree") == ["one", "two", "three"], "words splits on any whitespace")
assert(words("   ") == [], "words of only whitespace is empty")
assert(words("") == [], "words of empty is empty")

print("test_strings2: all tests passed ✓")
