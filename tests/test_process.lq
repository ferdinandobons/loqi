# run(): execute a shell command, capture stdout and exit code.
let r = run("echo hello")
assert(has(r, "out") and has(r, "code"), "run returns { out, code }")
assert(trim(r.out) == "hello", "run captures stdout")
assert(r.code == 0, "run captures a zero exit code")
assert(run("exit 7").code == 7, "run captures a non-zero exit code")

# args(): the CLI arguments after the script path (empty when none are passed).
assert(type(args()) == "list", "args() returns a list")

# (exit(code) is verified manually — it terminates the process, so it can't run
#  inside the suite.)

print("test_process: all tests passed ✓")
