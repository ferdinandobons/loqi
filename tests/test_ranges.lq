# Inclusive integer ranges: a..b -> [a, a+1, ..., b]
assert(1..5 == [1, 2, 3, 4, 5], "inclusive range")
assert(0..0 == [0], "single-element range")
assert(5..1 == [], "a > b is empty")
assert(-2..2 == [-2, -1, 0, 1, 2], "negative bounds")

# precedence: above ==, below arithmetic
let n = 4
assert(1..n == [1, 2, 3, 4], "range with a variable bound")
assert(0..n-1 == [0, 1, 2, 3], "0..n-1 parses as 0..(n-1)")
assert((1..3 == [1, 2, 3]) == true, "(1..3) == [...] compares the range")
let xs = ["a", "b", "c"]
assert(0..len(xs)-1 == [0, 1, 2], "0..len(xs)-1")

# iterate a range in a for loop
let total = 0
for i in 1..100 { total = total + i }
assert(total == 5050, "sum of 1..100")

# non-int bounds raise a catchable error
let bad = false
try { let r = 1.5..3 } catch e { bad = true }
assert(bad, "non-int range raises")

# the range() builtin: 1-, 2- and 3-argument forms
assert(range(3) == [0, 1, 2], "range(stop)")
assert(range(2, 5) == [2, 3, 4], "range(start, stop)")
assert(range(0, 10, 2) == [0, 2, 4, 6, 8], "range positive step")
assert(range(10, 0, -2) == [10, 8, 6, 4, 2], "range negative step")
assert(range(0, 10, -1) == [], "negative step with start < stop is empty")
assert(range(5, 5, 1) == [], "empty when start == stop")
let step0 = false
try { range(5, 10, 0) } catch e { step0 = true }
assert(step0, "range with step 0 raises")

print("test_ranges: all tests passed ✓")
