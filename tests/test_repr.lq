# str()/print() must never crash on cyclic structures (bounded recursion depth).
let a = [1, 2]
push(a, a)                                  # self-referential list
let s = str(a)
assert(type(s) == "str", "cyclic list stringifies to a string, no crash")
assert(contains(s, "..."), "cyclic list repr is depth-capped with ...")

let m = { k: 1 }
m["self"] = m                               # self-referential map
assert(contains(str(m), "..."), "cyclic map repr is depth-capped")

# normal (non-cyclic) nesting still renders in full
assert(str([[1, 2], [3]]) == "[[1, 2], [3]]", "nested lists render fully")
assert(str({ a: 1, b: [2, 3] }) == "{a: 1, b: [2, 3]}", "nested map renders fully")

print("test_repr: all tests passed ✓")
