# Regression tests for expression-form `if`: an `if` used in expression position
# yields the value of the taken branch. The statement form (a bare `if`) is unchanged.

# --- if as an expression ---
let g = 85
assert((if g >= 90 { "A" } else if g >= 80 { "B" } else { "C" }) == "B", "if/else-if/else chain yields a value")
assert((if true { 1 } else { 2 }) == 1, "if expression picks the then branch")
assert((if false { 1 } else { 2 }) == 2, "if expression picks the else branch")
assert((if false { 1 }) == nil, "an if with no else and a false condition yields nil")

# --- works in every expression position, even with temporaries on the stack ---
assert(len(if true { [1, 2, 3] } else { [] }) == 3, "if expression as a call argument")
assert([if true { 1 } else { 2 }, 3] == [1, 3], "if expression inside a list literal")
let parity = n => if n % 2 == 0 { "even" } else { "odd" }
assert(map([1, 2, 3, 4], parity) == ["odd", "even", "odd", "even"], "if expression as an arrow body")
assert((if g > 50 { if g > 80 { "high" } else { "mid" } } else { "low" }) == "high", "nested if expressions")

# --- a branch may run leading (side-effecting) statements; its value is the last expr ---
let val = if true {
  print("(if-expr branch side effect)")
  42
} else { 0 }
assert(val == 42, "a branch yields its last expression after running earlier statements")

# --- the statement form is unaffected (incl. `else` on its own line) ---
fn sign(n) {
  if n > 0 { return "pos" }
  else { return "neg" }
}
assert(sign(5) == "pos" and sign(-3) == "neg", "statement-form if still works")

# --- match still works as a statement ---
fn classify(n) {
  match n {
    0: { return "zero" }
    1, 2, 3: { return "small" }
    _: { return "big" }
  }
}
assert(classify(0) == "zero" and classify(2) == "small" and classify(99) == "big", "statement-form match still works")

print("test_expr_if_match: all tests passed ✓")
