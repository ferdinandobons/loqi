# Regression tests for modules: namespaced import, own-globals resolution,
# flat import, and import paths resolving relative to THIS file.

# --- namespaced import ---
import "fixtures/mathmod.lq" as m

assert(m.double(21) == 42, "module function via namespace")
assert(m.area(2) > 12.56 and m.area(2) < 12.57, "module fn resolves its own PI")
assert(m.PI == 3.14159, "module exposes its constants")

# a module exports exactly the names it defines — even ones that shadow a built-in
# (PI is a built-in constant, yet the module's own PI is what gets exported)...
assert(has(m, "PI") and has(m, "area") and has(m, "double"), "module exports its definitions")
# ...and built-ins the module did NOT define are not part of its namespace
assert(not has(m, "sqrt") and not has(m, "map"), "undeclared built-ins are not exported")

# --- flat import binds into the current scope ---
import "fixtures/mathmod.lq"
assert(double(10) == 20, "flat import binds names into current scope")
assert(area(1) > 3.14 and area(1) < 3.15, "flat-imported fn works with shared globals")

# --- a cyclic import raises a CATCHABLE error; it must never crash the process ---
let cycled = false
try { import "fixtures/cycle_a.lq" } catch e { cycled = true }
assert(cycled, "cyclic import is a catchable error, not a segfault")

print("test_modules: all tests passed ✓")
