# Regression tests for the vector / semantic-search (RAG) helpers:
# similarity (cosine), topk (nearest neighbours), normalize (unit vector).

# --- similarity (cosine) ---
assert(similarity([1, 0, 0], [1, 0, 0]) == 1.0, "identical vectors -> 1.0")
assert(similarity([1, 0], [0, 1]) == 0.0, "orthogonal vectors -> 0.0")
assert(similarity([0, 0], [1, 1]) == 0.0, "zero vector -> 0.0 (no divide-by-zero)")

# --- normalize (unit vector) ---
assert(normalize([3.0, 4.0]) == [0.6, 0.8], "3-4-5 triangle normalizes to 0.6/0.8")
assert(normalize([0, 0]) == [0, 0], "zero vector normalizes to itself")
let u = normalize([2, 0, 0])
assert(u == [1.0, 0.0, 0.0], "normalize collapses magnitude, keeps direction")

# --- topk: the RAG / nearest-neighbour primitive ---
let docs = [
  { text: "cats and kittens", vec: [1.0, 0.0, 0.0] },
  { text: "dogs and puppies", vec: [0.0, 1.0, 0.0] },
  { text: "felines purr",     vec: [0.9, 0.1, 0.0] },
  { text: "automobiles",      vec: [0.0, 0.0, 1.0] },
]
let hits = topk([1.0, 0.05, 0.0], map(docs, d => d.vec), 2)
assert(len(hits) == 2, "topk returns exactly k results")
assert(hits[0].index == 0, "the closest match is the cat document")
assert(hits[1].index == 2, "the second match is the feline document")
assert(hits[0].score >= hits[1].score, "results are sorted by descending score")
assert(docs[hits[0].index].text == "cats and kittens", "index maps back to the document")

# topk clamps k to the number of candidates, and handles the empty/zero cases
assert(len(topk([1, 0], [[1, 0], [0, 1]], 10)) == 2, "k larger than the set returns all")
assert(topk([1, 0], [], 3) == [], "no candidates -> empty")
assert(topk([1, 0], [[1, 0]], 0) == [], "k = 0 -> empty")

# huge-magnitude vectors must give FINITE, correct results (no overflow -> NaN),
# and cosine is clamped to its true [-1, 1] range
assert(similarity([1e200, 1e200, 1e200], [1e200, 1e200, 1e200]) > 0.999, "huge identical vectors -> ~1.0, not NaN")
assert(similarity([1e300, 0.0], [0.0, 1e300]) == 0.0, "huge orthogonal vectors -> 0.0")
assert(similarity([1, 0, 0], [-1, 0, 0]) == -1.0, "opposite vectors -> -1.0")
let unit = normalize([1e250, 1e250])
assert(unit[0] > 0.7 and unit[0] < 0.71, "huge vector normalizes to a real unit vector, not [0,0]")
let hits_big = topk([1e200, 0.0], [[1e200, 0.0], [0.0, 1e200]], 2)
assert(hits_big[0].index == 0 and hits_big[0].score > 0.999, "topk over huge vectors stays finite & correct")

# a deterministic tie is broken by the original index (stable order)
let tied = topk([1, 0], [[1, 0], [1, 0], [0, 1]], 2)
assert(tied[0].index == 0 and tied[1].index == 1, "ties keep the original order")

# --- a dimension/type mismatch is a catchable error, never a crash ---
let bad = false
try { topk([1, 0, 0], [[1, 0]], 1) } catch e { bad = true }
assert(bad, "topk reports a dimension mismatch as a catchable error")

print("test_vectors: all tests passed ✓")
